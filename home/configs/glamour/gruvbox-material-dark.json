{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#e2cca9",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "\u2502 ",
    "color": "#928374"
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#d3869b",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#1d2021",
    "background_color": "#d3869b",
    "bold": true
  },
  "h2": {
    "prefix": "## "
  },
  "h3": {
    "prefix": "### "
  },
  "h4": {
    "prefix": "#### "
  },
  "h5": {
    "prefix": "##### "
  },
  "h6": {
    "prefix": "###### ",
    "bold": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "#514036",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "\u2022 "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[\u2713] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#89b482",
    "underline": true
  },
  "link_text": {
    "color": "#d3869b",
    "bold": true
  },
  "image": {
    "color": "#d3869b",
    "underline": true
  },
  "image_text": {
    "color": "#d3869b",
    "format": "Image: {{.text}} \u2192"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#d3869b",
    "background_color": "#514036"
  },
  "code_block": {
    "color": "#e2cca9",
    "margin": 2,
    "chroma": {
      "text": {
        "color": "#e2cca9"
      },
      "error": {
        "color": "#e2cca9",
        "background_color": "#ea6962"
      },
      "comment": {
        "color": "#928374"
      },
      "comment_preproc": {
        "color": "#ea6962"
      },
      "keyword": {
        "color": "#d3869b"
      },
      "keyword_reserved": {
        "color": "#d3869b"
      },
      "keyword_namespace": {
        "color": "#d3869b"
      },
      "keyword_type": {
        "color": "#89b482"
      },
      "operator": {
        "color": "#d3869b"
      },
      "punctuation": {
        "color": "#e2cca9"
      },
      "name": {
        "color": "#e2cca9"
      },
      "name_builtin": {
        "color": "#89b482"
      },
      "name_tag": {
        "color": "#d3869b"
      },
      "name_attribute": {
        "color": "#a9b665"
      },
      "name_class": {
        "color": "#89b482",
        "underline": true,
        "bold": true
      },
      "name_constant": {
        "color": "#d3869b"
      },
      "name_decorator": {
        "color": "#a9b665"
      },
      "name_exception": {
        "color": "#ea6962"
      },
      "name_function": {
        "color": "#a9b665"
      },
      "name_other": {
        "color": "#e2cca9"
      },
      "literal": {
        "color": "#d8a657"
      },
      "literal_number": {
        "color": "#d3869b"
      },
      "literal_date": {
        "color": "#d8a657"
      },
      "literal_string": {
        "color": "#d8a657"
      },
      "literal_string_escape": {
        "color": "#d3869b"
      },
      "generic_deleted": {
        "color": "#ea6962"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "#a9b665"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "#89b482"
      },
      "generic_heading": {
        "color": "#e2cca9",
        "bold": true
      },
      "generic_output": {
        "color": "#e2cca9"
      },
      "generic_prompt": {
        "color": "#928374"
      },
      "generic_error": {
        "color": "#ea6962"
      },
      "generic_traceback": {
        "color": "#ea6962"
      },
      "background": {
        "background_color": "#1d2021"
      }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n\ud83e\udc36 "
  }
}