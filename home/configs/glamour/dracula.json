{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#f8f8f2",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "color": "#6272a4"
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#bd93f9",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#282a36",
    "background_color": "#ff79c6",
    "bold": true
  },
  "h2": { "prefix": "## " },
  "h3": { "prefix": "### " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### ", "bold": false },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "italic": true },
  "strong": { "bold": true },
  "hr": {
    "color": "#44475a",
    "format": "\n--------\n"
  },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#8be9fd",
    "underline": true
  },
  "link_text": {
    "color": "#bd93f9",
    "bold": true
  },
  "image": {
    "color": "#ff79c6",
    "underline": true
  },
  "image_text": {
    "color": "#ff79c6",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#ff79c6",
    "background_color": "#44475a"
  },
  "code_block": {
    "color": "#f8f8f2",
    "margin": 2,
    "chroma": {
      "text": { "color": "#f8f8f2" },
      "error": { "color": "#f8f8f2", "background_color": "#ff5555" },
      "comment": { "color": "#6272a4" },
      "comment_preproc": { "color": "#ff5555" },
      "keyword": { "color": "#ff79c6" },
      "keyword_reserved": { "color": "#ff79c6" },
      "keyword_namespace": { "color": "#ff79c6" },
      "keyword_type": { "color": "#8be9fd" },
      "operator": { "color": "#ff79c6" },
      "punctuation": { "color": "#f8f8f2" },
      "name": { "color": "#f8f8f2" },
      "name_builtin": { "color": "#8be9fd" },
      "name_tag": { "color": "#ff79c6" },
      "name_attribute": { "color": "#50fa7b" },
      "name_class": { "color": "#8be9fd", "underline": true, "bold": true },
      "name_constant": { "color": "#bd93f9" },
      "name_decorator": { "color": "#50fa7b" },
      "name_exception": { "color": "#ff5555" },
      "name_function": { "color": "#50fa7b" },
      "name_other": { "color": "#f8f8f2" },
      "literal": { "color": "#f1fa8c" },
      "literal_number": { "color": "#bd93f9" },
      "literal_date": { "color": "#f1fa8c" },
      "literal_string": { "color": "#f1fa8c" },
      "literal_string_escape": { "color": "#ff79c6" },
      "generic_deleted": { "color": "#ff5555" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#50fa7b" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#8be9fd" },
      "generic_heading": { "color": "#f8f8f2", "bold": true },
      "generic_output": { "color": "#f8f8f2" },
      "generic_prompt": { "color": "#6272a4" },
      "generic_error": { "color": "#ff5555" },
      "generic_traceback": { "color": "#ff5555" },
      "background": { "background_color": "#282a36" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " }
}
